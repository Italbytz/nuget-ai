graph G {
bgcolor="#FFFFFF00"; rankdir=LR;
0 [label="H", style=solid];
1 [label="B", style=dotted];
2 [label="E", style=solid];
3 [label="A", style=solid];
4 [label="F", style=solid];
5 [label="D", style=solid];
