@page "/weighted-graph"
@using Italbytz.AI.Demos.Web.Demos
@using Italbytz.AI.Search.Demos.WeightedGraph
@using Italbytz.Graph
@using Italbytz.Graph.Abstractions
@using Italbytz.Graph.Visualization

<PageTitle>Weighted graph demo</PageTitle>

<section class="demo-hero">
    <div>
        <p class="eyebrow">Search demo</p>
        <h1>Weighted Graph</h1>
        <p class="hero-copy">Step through a Dijkstra-style uniform-cost search on a small weighted graph and inspect every relaxation, frontier reorder, and shortest-path update.</p>
    </div>

    <div class="stat-grid">
        <article>
            <span class="stat-label">Scenario</span>
            <strong>@_scenario.Name</strong>
        </article>
        <article>
            <span class="stat-label">Start node</span>
            <strong>@_scenario.StartNode</strong>
        </article>
        <article>
            <span class="stat-label">Expanded node</span>
            <strong>@(CurrentStep?.ExpandedNode.State ?? _scenario.StartNode)</strong>
        </article>
        <article>
            <span class="stat-label">Visible step</span>
            <strong>@VisibleProgressLabel</strong>
        </article>
    </div>
</section>

<section class="control-panel">
    <div class="secondary-controls">
        <div class="selection-copy">
            <p class="selection-summary">@_scenario.Summary</p>
            <p class="selection-summary">This page is driven by the package-level <code>WeightedGraphSearchSimulator</code> and mirrors the queue discipline of uniform-cost search / Dijkstra. Graph rendering uses <code>Italbytz.Graph.Blazor</code>.</p>
        </div>

        <div class="step-buttons">
            <button class="ghost-button" @onclick="RandomizeScenario">Randomize setup</button>
            <button class="ghost-button" @onclick="PreviousStep" disabled="@(_currentStep == 0)">Previous</button>
            <button class="primary-button" @onclick="NextStep" disabled="@(_currentStep >= _result.Steps.Count)">Next</button>
            <button class="ghost-button" @onclick="ShowCompleteRun" disabled="@(_currentStep >= _result.Steps.Count)">Complete run</button>
            <button class="ghost-button" @onclick="Reset">Reset</button>
        </div>
    </div>

    <p class="step-summary">@CurrentSummary</p>
</section>

<section class="demo-grid">
    <article class="surface-card map-card">
        <div class="section-heading">
            <h2>Graph</h2>
            <p>Nodes display their current best-known distance. Accepted relaxations and the current shortest-path tree are highlighted as you advance.</p>
        </div>

        <GraphViewport Graph="@_graphView"
                       ActiveEdgeKeys="@CurrentGraphState.ActiveEdgeKeys"
                       ActiveNodeKeys="@CurrentGraphState.ActiveNodeIds"
                       FrontierNodeKeys="@CurrentGraphState.FrontierNodeIds"
                       ExploredNodeKeys="@CurrentGraphState.ExploredNodeIds"
                       CurrentNodeKey="@CurrentGraphState.CurrentNodeId"
                       SuccessorEdgeKeys="@CurrentGraphState.SuccessorEdgeKeys"
                       DirectedActiveEdgeIds="@CurrentGraphState.DirectedActiveEdgeIds"
                       DirectedSuccessorEdgeIds="@CurrentGraphState.DirectedSuccessorEdgeIds"
                       Title="Dijkstra shortest-path search"
                       ZoomInLabel="Zoom in"
                       ZoomOutLabel="Zoom out"
                       FitLabel="Fit graph"
                       ResetLabel="Reset"
                       InteractionHint="Use the graph itself to inspect nodes, edges and the current search state."
                       ActiveLegendLabel="Shortest-path tree"
                       SuccessorLegendLabel="Candidate edges"
                       CurrentNodeLegendLabel="Expanded node"
                       FrontierLegendLabel="Frontier"
                       ExploredLegendLabel="Reached"
                       SolutionLegendLabel="Shortest path"
                       DefaultLegendLabel="Alternative edge"
                       InspectorTitle="Inspector"
                       NoSelectionTitle="Nothing selected"
                       NoSelectionText="Select a node or edge in the graph to inspect its current role."
                       NodeLabel="Node"
                       EdgeLabel="Edge"
                       WeightLabel="Weight"
                       ConnectionsLabel="Connections"
                       StateLabel="State" />
    </article>

    <article class="surface-card inspector-card">
        <div class="section-heading">
            <h2>Trace and distances</h2>
            <p>Reveal the run step by step and inspect both the queue state and the current shortest-path table.</p>
        </div>

        @if (VisibleSteps.Count == 0)
        {
            <p class="empty-copy">No step revealed yet. Advance the search to expand the first node.</p>
        }
        else
        {
            <ol class="trace-list step-trace-list">
                @foreach (var step in VisibleSteps)
                {
                    <li class="@(step.StepNumber == _currentStep ? "trace-step-active" : string.Empty)">
                        <strong>@step.StepNumber. Expand @step.ExpandedNode.State</strong>
                        <span>Frontier: @(step.Frontier.Count == 0 ? "empty" : string.Join(", ", step.Frontier.Select(node => $"{node.State}({node.Priority:0.##})")))</span>
                    </li>
                }
            </ol>
        }

        <div class="trace-columns">
            <div>
                <h3>Distances</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Node</th>
                            <th>Distance</th>
                            <th>Prev</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var distance in CurrentDistances)
                        {
                            <tr class="@(string.Equals(distance.Node, CurrentStep?.ExpandedNode.State, StringComparison.Ordinal) ? "distance-row-active" : string.Empty)">
                                <td>@distance.Node</td>
                                <td>@WeightedGraphDemoFactory.FormatDistance(distance.Distance)</td>
                                <td>@(distance.PreviousNode ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div>
                <h3>Relaxations</h3>
                @if (CurrentRelaxations.Count == 0)
                {
                    <p class="empty-copy">No relaxation visible at the current step.</p>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th>Edge</th>
                                <th>Candidate</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var relaxation in CurrentRelaxations)
                            {
                                <tr class="@(relaxation.Accepted ? "relaxation-accepted" : "relaxation-rejected")">
                                    <td>@relaxation.FromNode -> @relaxation.ToNode</td>
                                    <td>@relaxation.CandidateDistance.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)</td>
                                    <td>@(relaxation.Accepted ? "accepted" : "rejected")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </article>
</section>

@code {
    private readonly Random _random = new();
    private WeightedGraphScenario _scenario = WeightedGraphDemoFactory.BuildScenarios()[0];
    private WeightedGraphSearchResult _result = new WeightedGraphSearchSimulator().SimulateDijkstra(
        WeightedGraphDemoFactory.BuildScenarios()[0].StartNode,
        WeightedGraphDemoFactory.BuildScenarios()[0].Vertices,
        WeightedGraphDemoFactory.BuildScenarios()[0].Edges);
    private int _currentStep;
    private GraphViewModel _graphView = null!;

    protected override void OnInitialized()
    {
        RecreateGraph();
    }

    private void RecreateGraph()
    {
        var graph = CreateGraph();
        _graphView = GraphViewFactory.BuildSvgGraphView(graph, Array.Empty<string>());
    }

    private IReadOnlyList<WeightedGraphSearchStep> VisibleSteps => _result.Steps.Take(_currentStep).ToArray();
    private WeightedGraphSearchStep? CurrentStep => _currentStep > 0 && _result.Steps.Count > 0 ? _result.Steps[_currentStep - 1] : null;
    private IReadOnlyList<WeightedGraphDistanceState> CurrentDistances => CurrentStep?.Distances ?? _result.Distances;
    private IReadOnlyList<WeightedGraphRelaxation> CurrentRelaxations => CurrentStep?.Relaxations ?? [];
    private string VisibleProgressLabel => _result.Steps.Count == 0 ? "0 / 0" : $"{_currentStep} / {_result.Steps.Count}";
    private string CurrentSummary => _currentStep switch
    {
        0 => "Start with the initial node, then step through the queue discipline to see how Dijkstra relaxes edges and reorders the frontier.",
        _ => $"Step {_currentStep}: expand {CurrentStep?.ExpandedNode.State}, inspect relaxations, and compare the frontier ordering."
    };

    private GraphStateViewModel CurrentGraphState => BuildGraphState();

    private void RandomizeScenario()
    {
        _scenario = WeightedGraphDemoFactory.CreateRandomScenario(_random);
        _result = new WeightedGraphSearchSimulator().SimulateDijkstra(_scenario.StartNode, _scenario.Vertices, _scenario.Edges);
        _currentStep = 0;
        RecreateGraph();
    }

    private void PreviousStep()
    {
        if (_currentStep > 0)
        {
            _currentStep--;
        }
    }

    private void NextStep()
    {
        if (_currentStep < _result.Steps.Count)
        {
            _currentStep++;
        }
    }

    private void ShowCompleteRun()
    {
        _currentStep = _result.Steps.Count;
    }

    private void Reset()
    {
        _currentStep = 0;
    }

    private IUndirectedGraph<string, ITaggedEdge<string, double>> CreateGraph()
    {
        var edges = new List<ITaggedEdge<string, double>>();
        
        foreach (var edge in _scenario.Edges)
        {
            edges.Add(new TaggedEdge<string, double>(edge.FromNode, edge.ToNode, edge.Cost));
        }

        return new UndirectedGraph<string, ITaggedEdge<string, double>>
        {
            Edges = edges.ToArray()
        };
    }

    private GraphStateViewModel BuildGraphState()
    {
        if (CurrentStep is null)
        {
            var startNode = _scenario.StartNode;
            return new GraphStateViewModel(
                startNode,                      // CurrentNodeId
                [startNode],                    // ActiveNodeIds
                [],                             // FrontierNodeIds
                [],                             // ExploredNodeIds
                [],                             // ActiveEdgeKeys
                [],                             // SuccessorEdgeKeys
                [],                             // DirectedActiveEdgeIds
                []);                            // DirectedSuccessorEdgeIds
        }

        // Build the graph state for the current step
        var expandedNode = CurrentStep.ExpandedNode.State;
        var reachedNodes = CurrentDistances
            .Where(d => d.Distance.HasValue)
            .Select(d => d.Node)
            .ToList();
        var frontierNodes = CurrentStep.Frontier.Select(f => f.State).ToArray();
        
        // Tree edges from shortest-path tree (parent to child nodes)
        var treeEdgeIds = new List<string>();
        var directedTreeEdgeIds = new List<string>();
        
        foreach (var distance in CurrentDistances)
        {
            if (!string.IsNullOrEmpty(distance.PreviousNode) && distance.Distance.HasValue)
            {
                var parentNode = distance.PreviousNode;
                var childNode = distance.Node;
                treeEdgeIds.Add($"{parentNode}-{childNode}");
                directedTreeEdgeIds.Add(GraphViewKeys.CreateDirectedEdgeId(parentNode, childNode));
            }
        }

        // Successor edges are the candidate edges from the current expanded node
        var successorEdgeIds = new List<string>();
        var directedSuccessorEdgeIds = new List<string>();
        
        var relaxationsInStep = CurrentStep?.Relaxations ?? [];
        foreach (var relaxation in relaxationsInStep)
        {
            successorEdgeIds.Add($"{relaxation.FromNode}-{relaxation.ToNode}");
            directedSuccessorEdgeIds.Add(GraphViewKeys.CreateDirectedEdgeId(relaxation.FromNode, relaxation.ToNode));
        }

        return new GraphStateViewModel(
            expandedNode,                       // CurrentNodeId
            reachedNodes.ToArray(),             // ActiveNodeIds (all reached nodes)
            frontierNodes,                      // FrontierNodeIds
            [],                                 // ExploredNodeIds (not used in Dijkstra)
            treeEdgeIds.ToArray(),              // ActiveEdgeKeys (shortest-path tree)
            successorEdgeIds.ToArray(),         // SuccessorEdgeKeys (candidates)
            directedTreeEdgeIds.ToArray(),      // DirectedActiveEdgeIds
            directedSuccessorEdgeIds.ToArray()); // DirectedSuccessorEdgeIds
    }
}