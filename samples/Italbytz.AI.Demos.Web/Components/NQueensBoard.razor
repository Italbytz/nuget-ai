@namespace Italbytz.AI.Demos.Web.Components

<div class="board-shell">
    <div class="board" style="--board-size:@BoardSize">
        @for (var row = 0; row < BoardSize; row++)
        {
            @for (var column = 0; column < BoardSize; column++)
            {
                var r = row;
                var c = column;
                <div class="@GetCellClass(c, r)" title="@GetCellTitle(c, r)">
                    @if (IsAssigned(c) && QueenRows[c] == r)
                    {
                        <svg class="queen-icon" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
                            <circle cx="14" cy="15" r="4"></circle>
                            <circle cx="26" cy="11" r="4"></circle>
                            <circle cx="38" cy="11" r="4"></circle>
                            <circle cx="50" cy="15" r="4"></circle>
                            <path d="M 14 20 L 22 38 L 32 24 L 42 38 L 50 20 L 47 46 L 17 46 Z"></path>
                            <rect x="15" y="46" width="34" height="6" rx="2"></rect>
                        </svg>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public int BoardSize { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<int> QueenRows { get; set; } = [];
    [Parameter] public IReadOnlyList<int> ConflictedColumns { get; set; } = [];
    [Parameter] public IReadOnlyList<int>? AssignedColumns { get; set; }
    [Parameter] public int? CurrentColumn { get; set; }

    private string GetCellClass(int column, int row)
    {
        var isDarkCell = (row + column) % 2 == 1;
        var cssClass = isDarkCell ? "board-cell board-cell-dark" : "board-cell board-cell-light";

        if (IsAssigned(column) && QueenRows[column] == row)
        {
            cssClass += " board-cell-has-queen";

            if (ConflictedColumns.Contains(column))
            {
                cssClass += " board-cell-conflicted";
            }

            if (CurrentColumn == column)
            {
                cssClass += " board-cell-current";
            }
        }

        return cssClass;
    }

    private string GetCellTitle(int column, int row)
    {
        if (!IsAssigned(column))
        {
            return $"Column {column + 1} is unassigned";
        }

        if (QueenRows[column] != row)
        {
            return $"Column {column + 1}, row {row + 1}";
        }

        return CurrentColumn == column
            ? $"Q{column + 1} is currently being modified"
            : $"Q{column + 1} in row {row + 1}";
    }

    private bool IsAssigned(int column)
    {
        return AssignedColumns is null || AssignedColumns.Contains(column);
    }
}
