@using Italbytz.AI.Demos.Web.Demos
@using Italbytz.Graph.Visualization

@if (Tree is not null && _graphView is not null)
{
    <div class="game-tree-container">
        <GraphViewport Graph="@_graphView"
                       ActiveEdgeKeys="@_graphState.ActiveEdgeKeys"
                       ActiveNodeKeys="@_graphState.ActiveNodeIds"
                       FrontierNodeKeys="@_graphState.FrontierNodeIds"
                       ExploredNodeKeys="@_graphState.ExploredNodeIds"
                       CurrentNodeKey="@_graphState.CurrentNodeId"
                       SuccessorEdgeKeys="@_graphState.SuccessorEdgeKeys"
                       DirectedActiveEdgeIds="@_graphState.DirectedActiveEdgeIds"
                       DirectedSuccessorEdgeIds="@_graphState.DirectedSuccessorEdgeIds"
                       Title="Tic-Tac-Toe game tree"
                       ZoomInLabel="Zoom in"
                       ZoomOutLabel="Zoom out"
                       FitLabel="Fit tree"
                       ResetLabel="Reset"
                       InteractionHint="Nutze Zoom/Fit und klicke Knoten/Kanten für Details."
                       ActiveLegendLabel="Principal variation"
                       SuccessorLegendLabel="Alternativen"
                       CurrentNodeLegendLabel="Root"
                       FrontierLegendLabel="Nicht-terminal"
                       ExploredLegendLabel="Terminal"
                       SolutionLegendLabel="PV-Knoten"
                       DefaultLegendLabel="Normale Kante"
                       InspectorTitle="Tree inspector"
                       NoSelectionTitle="Nichts ausgewählt"
                       NoSelectionText="Wähle einen Knoten oder eine Kante, um Utility und Verbindungen zu prüfen."
                       NodeLabel="Node"
                       EdgeLabel="Edge"
                       WeightLabel="Utility"
                       ConnectionsLabel="Connections"
                       StateLabel="State" />
    </div>
}

@code {
    [Parameter]
    public TicTacToeGameTree? Tree { get; set; }

    [Parameter]
    public bool CondenseBeforeDecision { get; set; } = true;

    private GraphViewModel? _graphView;
    private GraphStateViewModel _graphState = new(string.Empty, [], [], [], [], [], [], []);

    protected override void OnParametersSet()
    {
        if (Tree is null)
        {
            _graphView = null;
            _graphState = new(string.Empty, [], [], [], [], [], [], []);
            return;
        }

        var treeLayoutNodes = new List<TreeLayoutNode>();
        var activeNodeIds = new List<string>();
        var frontierNodeIds = new List<string>();
        var exploredNodeIds = new List<string>();
        var activeEdgeKeys = new List<string>();
        var directedActiveEdgeIds = new List<string>();

        // Show only the selected path from root to the current decision (depth 1),
        // then expand all continuations from there to leaves.
        BuildTreeState(
            Tree.Root,
            null,
            0,
            treeLayoutNodes,
            activeNodeIds,
            frontierNodeIds,
            exploredNodeIds,
            activeEdgeKeys,
            directedActiveEdgeIds,
            expandAllFromDepth: CondenseBeforeDecision ? 1 : 0);

        _graphView = GraphViewFactory.BuildTreeGraphView(
            treeLayoutNodes,
            horizontalSpacing: 108.0,
            verticalSpacing: 220.0,
            nodeRadius: 24.0,
            padding: 56.0,
            rootSpacing: 1.4,
            orientation: TreeLayoutOrientation.LeftToRight);

        _graphState = new GraphStateViewModel(
            Tree.Root.Id,
            activeNodeIds,
            frontierNodeIds,
            exploredNodeIds,
            activeEdgeKeys,
            [],
            directedActiveEdgeIds,
            []);
    }

    private static void BuildTreeState(
        TicTacToeTreeNode node,
        string? parentId,
        int order,
        ICollection<TreeLayoutNode> treeLayoutNodes,
        ICollection<string> activeNodeIds,
        ICollection<string> frontierNodeIds,
        ICollection<string> exploredNodeIds,
        ICollection<string> activeEdgeKeys,
        ICollection<string> directedActiveEdgeIds,
        int expandAllFromDepth)
    {
        var label = node.Label ?? "?";
        var edgeLabel = node.Move is null ? string.Empty : node.Utility.ToString("0.##");

        treeLayoutNodes.Add(new TreeLayoutNode(node.Id, label, parentId, edgeLabel, node.OnPrincipalVariation, order));

        if (node.OnPrincipalVariation)
        {
            activeNodeIds.Add(node.Id);
        }

        if (node.IsTerminal)
        {
            exploredNodeIds.Add(node.Id);
        }
        else
        {
            frontierNodeIds.Add(node.Id);
        }

        var childrenToTraverse = node.Depth < expandAllFromDepth
            ? node.Children.Where(c => c.OnPrincipalVariation).ToList()
            : node.Children;

        if (childrenToTraverse.Count == 0 && node.Depth < expandAllFromDepth)
        {
            // Fallback when no PV marker is present.
            childrenToTraverse = node.Children;
        }

        foreach (var child in childrenToTraverse)
        {
            var edgeKey = $"{node.Id}->{child.Id}";
            var directedId = GraphViewKeys.CreateDirectedEdgeId(node.Id, child.Id);

            if (child.OnPrincipalVariation)
            {
                activeEdgeKeys.Add(edgeKey);
                directedActiveEdgeIds.Add(directedId);
            }

            BuildTreeState(
                child,
                node.Id,
                child.Move?.Index ?? 0,
                treeLayoutNodes,
                activeNodeIds,
                frontierNodeIds,
                exploredNodeIds,
                activeEdgeKeys,
                directedActiveEdgeIds,
                expandAllFromDepth);
        }
    }
}
